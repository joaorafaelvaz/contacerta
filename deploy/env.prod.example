# ContaCerta — produção (contacerta.linkwise.digital)
# CLI: copie para .env.prod na raiz do repo e preencha.
# Portainer: cole estas variáveis (preenchidas) no campo "Environment variables" da stack.

# gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://contacerta.linkwise.digital

POSTGRES_USER=contacerta
# gere com: openssl rand -hex 16
POSTGRES_PASSWORD=
POSTGRES_DB=contacerta

# porta local que o nginx nativo proxeia (127.0.0.1:3078 → container:3000)
APP_PORT=3078

# WhatsApp via WAHA já rodando no VPS.
# Se o WAHA é um container publicado numa porta do host, use:
#   WAHA_URL=http://host.docker.internal:<porta-do-waha>
# Configure no WAHA o webhook: https://contacerta.linkwise.digital/api/waha/webhook
# com o header customizado x-webhook-secret = WAHA_WEBHOOK_SECRET abaixo.
WAHA_URL=
WAHA_API_KEY=
WAHA_SESSION=default
# gere com: openssl rand -hex 16
WAHA_WEBHOOK_SECRET=

# Ollama para interpretar lançamentos em linguagem natural no WhatsApp.
# Vazio = bot responde só aos comandos fixos (saldo, fatura, contas, paguei).
# Ollama no host: OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_URL=
OLLAMA_MODEL=llama3.2

# resumo diário de contas a pagar no WhatsApp (8h, fuso abaixo)
REMINDER_CRON=0 8 * * *
TZ=America/Sao_Paulo
