# Copie para .env e ajuste
DATABASE_URL=postgres://meusaldo:meusaldo@localhost:5434/meusaldo
BETTER_AUTH_SECRET=troque-por-um-segredo-longo-aleatorio
# local: http://localhost:3002 | produção: https://contacerta.linkwise.digital
BETTER_AUTH_URL=http://localhost:3002

# WhatsApp via WAHA (Fase 2) — deixe WAHA_URL vazio para desativar o bot
WAHA_URL=
WAHA_API_KEY=
WAHA_SESSION=default
WAHA_WEBHOOK_SECRET=
# LLM local para interpretar lançamentos em linguagem natural
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Resumo diário (cron); TZ do container controla o fuso
REMINDER_CRON=0 8 * * *
TZ=America/Sao_Paulo

# Produção (docker compose --profile prod)
POSTGRES_USER=meusaldo
POSTGRES_PASSWORD=meusaldo
POSTGRES_DB=meusaldo
POSTGRES_PORT=5434
APP_PORT=3002
